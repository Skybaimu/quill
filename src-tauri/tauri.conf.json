{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Quill",
  "version": "1.6.1",
  "identifier": "com.skybaimu.quill",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Quill",
        "width": 1100,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "cli": {
      "description": "Quill CLI interface",
      "args": [
        {
          "name": "file",
          "index": 1,
          "takesValue": true,
          "multiple": false
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "app", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdown", "mkd"],
        "mimeType": "text/markdown",
        "description": "Markdown 文档"
      },
      {
        "ext": ["txt"],
        "mimeType": "text/plain",
        "description": "纯文本文档"
      }
    ],
    "windows": {
      "nsis": {
        "template": null,
        "installMode": "both",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": false
      },
      "wix": null
    },
    "macOS": {
      "exceptionDomain": ""
    }
  }
}
